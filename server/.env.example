DATABASE_URL=postgresql://user:password@db-host:5432/ticket_db?sslmode=require
CLIENT_URL=http://localhost:5173

# Webhook secret — set to a strong random string to enable POST /api/webhooks/ticket
WEBHOOK_SECRET=

# IMAP inbound email — leave blank to disable email ingestion
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=support@example.com
IMAP_PASSWORD=your-imap-password
EMAIL_POLL_INTERVAL=60
