DATABASE_URL=postgresql://user:password@db-host:5432/ticket_db?sslmode=require
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=<generate-with-openssl-rand-base64-32>
BETTER_AUTH_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173
SEED_ADMIN_EMAIL=admin@example.com
# Must be at least 16 characters
SEED_ADMIN_PASSWORD=<use-a-strong-passphrase>
# Optional — seeds a second (non-admin) agent account. Leave both blank to skip.
SEED_AGENT_EMAIL=
SEED_AGENT_PASSWORD=

# Required for AI features (classify / summarize / polish reply) — leave blank to disable them
OPENAI_API_KEY=

# Sentry — leave blank to disable error reporting
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
